{
  "name": "@devli13/paperclip-plugin-discord",
  "version": "0.9.2",
  "description": "Fork of paperclip-plugin-discord by @mvanhorn. Adds free-form @mention routing, DM support, and a serialized per-context message queue so agents can respond to community conversation end-to-end in Discord.",
  "type": "module",
  "main": "./dist/index.js",
  "paperclipPlugin": {
    "manifest": "./dist/manifest.js",
    "worker": "./dist/worker.js"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "dev": "tsc --watch",
    "test": "vitest run",
    "prepublishOnly": "npm run build",
    "prepare": "npm run build"
  },
  "peerDependencies": {
    "@paperclipai/plugin-sdk": "*",
    "@paperclipai/shared": "*"
  },
  "devDependencies": {
    "@paperclipai/plugin-sdk": "^2026.403.0",
    "@paperclipai/shared": "^2026.403.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE",
    "ATTRIBUTION.md",
    "UPSTREAM_DIFF.md"
  ],
  "keywords": [
    "paperclip",
    "paperclip-plugin",
    "discord",
    "discord-bot",
    "community",
    "moderation",
    "ai-agents"
  ],
  "author": "devli13",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/devli13/paperclip-plugin-discord.git"
  },
  "bugs": {
    "url": "https://github.com/devli13/paperclip-plugin-discord/issues"
  },
  "homepage": "https://github.com/devli13/paperclip-plugin-discord#readme",
  "publishConfig": {
    "access": "public"
  }
}
